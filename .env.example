# Encryption
ENCRYPTION_MASTER_KEY=

# Database
DATABASE_URL=

# Redis (Upstash) — must use TLS: rediss:// (not redis://)
UPSTASH_REDIS_URL=

# BullMQ worker tuning (Railway cron service + local manual worker)
# WORKER_CONCURRENCY=5
# WORKER_DRAIN_DELAY_SEC=120
# WORKER_LOCK_DURATION_MS=120000
# WORKER_LOCK_RENEW_MS=60000
# WORKER_MAX_RUN_MS=3600000

# Auth
JWT_SECRET=
NEXT_PUBLIC_APP_URL=

# Pimlico (required on Vercel + Railway — bundler/paymaster for GoClaim UserOps)
PIMLICO_API_KEY=

# Internal cron auth
CRON_SECRET=

# Celo RPC — primary with automatic Forno fallback on transport errors
# Optional full URL override (wins over DRPC key)
# CELO_RPC_URL=https://forno.celo.org
# NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org

# DRPC for reliable Celo RPC (server-side reads / worker); falls back to Forno
DRPC_API_KEY=

# Client-side Celo RPC (wallet reads); falls back to Forno
NEXT_PUBLIC_DRPC_API_KEY=

# WalletConnect project ID (required for WalletConnect in the connect modal)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Worker claim test
USER_ID=

# GoClaim on-chain logger (EIP-712 signer; must match on-chain goClaimSigner)
APP_PRIVATE_KEY=
