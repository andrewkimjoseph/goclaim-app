# Encryption
ENCRYPTION_MASTER_KEY=

# Database
DATABASE_URL=

# Redis (Upstash) — must use TLS: rediss:// (not redis://)
UPSTASH_REDIS_URL=

# BullMQ worker tuning (Railway worker service only)
# WORKER_CONCURRENCY=5
# WORKER_DRAIN_DELAY_SEC=30

# Auth
JWT_SECRET=
NEXT_PUBLIC_APP_URL=

# Pimlico
PIMLICO_API_KEY=

# Internal cron auth
CRON_SECRET=

# DRPC for reliable Celo RPC (server-side reads / worker)
DRPC_API_KEY=

# Client-side Celo RPC (wallet reads, same DRPC endpoint)
NEXT_PUBLIC_DRPC_API_KEY=

# WalletConnect project ID (required for WalletConnect in the connect modal)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Worker claim test
USER_ID=
