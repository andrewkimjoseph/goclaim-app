generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String                       @id @default(cuid())
  rootAddress                 String                       @unique
  createdAt                   DateTime                     @default(now())
  goClaimWallet               GoClaimWallet?
  claimLogs                   ClaimLog[]
  transferLogs                TransferLog[]
  connectAccountLog           ConnectAccountLog?
  goClaimAccountCreatedLog    GoClaimAccountCreatedLog?
  goClaimAccountConnectedLog  GoClaimAccountConnectedLog?
  goClaimUbiClaimedLogs       GoClaimUbiClaimedLog[]
  goClaimTokenTransferredLogs GoClaimTokenTransferredLog[]
}

model GoClaimWallet {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id])
  goClaimAccountAddress String    @unique
  eoaAddress            String
  encryptedPrivateKey   String
  iv                    String
  keyVersion            String    @default("v1")
  createdAt             DateTime  @default(now())
  lastClaimedAt         DateTime?
  isActive              Boolean   @default(true)
}

model ClaimLog {
  id                        String                      @id @default(cuid())
  userId                    String
  user                      User                        @relation(fields: [userId], references: [id])
  status                    String
  txHash                    String?
  errorMsg                  String?
  claimedAt                 DateTime                    @default(now())
  claimedDate               DateTime                    @db.Date
  waveIndex                 Int?
  transfer                  TransferLog?
  goClaimUbiClaimedLog      GoClaimUbiClaimedLog?
  goClaimTokenTransferredLog GoClaimTokenTransferredLog?

  @@unique([userId, claimedDate])
  @@index([userId, claimedDate])
}

model TransferLog {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  claimLogId       String   @unique
  claimLog         ClaimLog @relation(fields: [claimLogId], references: [id])
  recipientAddress String
  amountWei        String
  txHash           String
  userOpHash       String
  transferredAt    DateTime @default(now())
}

model ConnectAccountLog {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id])
  goClaimAccountAddress String
  rootAddress           String
  txHash                String   @unique
  connectedAt           DateTime @default(now())
}

model GoClaimAccountCreatedLog {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id])
  goClaimAccountAddress String
  txHash                String
  userOpHash            String
  loggedAt              DateTime @default(now())
}

model GoClaimAccountConnectedLog {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id])
  goClaimAccountAddress String
  rootAddress           String
  txHash                String
  userOpHash            String
  loggedAt              DateTime @default(now())
}

model GoClaimUbiClaimedLog {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id])
  claimLogId            String   @unique
  claimLog              ClaimLog @relation(fields: [claimLogId], references: [id])
  goClaimAccountAddress String
  rootAddress           String
  tokenAddress          String
  amountWei             String
  txHash                String
  userOpHash            String
  loggedAt              DateTime @default(now())
}

model GoClaimTokenTransferredLog {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id])
  claimLogId            String   @unique
  claimLog              ClaimLog @relation(fields: [claimLogId], references: [id])
  goClaimAccountAddress String
  recipientAddress      String
  tokenAddress          String
  amountWei             String
  txHash                String
  userOpHash            String
  loggedAt              DateTime @default(now())
}

model Nonce {
  id        String   @id @default(cuid())
  address   String
  nonce     String
  expiresAt DateTime

  @@index([address, expiresAt])
}
