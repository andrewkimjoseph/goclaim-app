generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  rootAddress        String              @unique
  createdAt          DateTime            @default(now())
  goClaimWallet      GoClaimWallet?
  claimLogs          ClaimLog[]
  transferLogs       TransferLog[]
  connectAccountLog  ConnectAccountLog?
}

model GoClaimWallet {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id])
  goClaimAccountAddress String    @unique
  eoaAddress            String
  encryptedPrivateKey   String
  iv                    String
  keyVersion            String    @default("v1")
  createdAt             DateTime  @default(now())
  lastClaimedAt         DateTime?
  isActive              Boolean   @default(true)
}

model ClaimLog {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  status    String
  txHash    String?
  errorMsg  String?
  claimedAt DateTime     @default(now())
  waveIndex Int?
  transfer  TransferLog?
}

model TransferLog {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  claimLogId       String   @unique
  claimLog         ClaimLog @relation(fields: [claimLogId], references: [id])
  recipientAddress String
  amountWei        String
  txHash           String
  userOpHash       String
  transferredAt    DateTime @default(now())
}

model ConnectAccountLog {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id])
  goClaimAccountAddress String
  rootAddress           String
  txHash                String   @unique
  connectedAt           DateTime @default(now())
}

model Nonce {
  id        String   @id @default(cuid())
  address   String
  nonce     String
  expiresAt DateTime

  @@index([address, expiresAt])
}
